SECRET_KEY=your-secret-key-here
DEBUG=True
DATABASE_URL=postgres://undangan_user:undangan_pass@db:5432/undangan_db
DB_NAME=undangan_db
DB_USER=undangan_user
DB_PASSWORD=undangan_pass
DB_HOST=db
DB_PORT=5432
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173
MEDIA_ROOT=/app/media
ADMIN_WHATSAPP_NUMBER=628123456789

# Public URL of the frontend (used in password-reset emails & share links)
FRONTEND_URL=http://localhost:5173

# Email — console backend prints to logs in dev. For production set SMTP:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Undangan Digital <noreply@undangan.local>
ADMIN_EMAIL=admin@undangan.local

# Production-only HTTPS / CSRF (comma-separated, e.g. https://undangan.com)
CSRF_TRUSTED_ORIGINS=
SECURE_SSL_REDIRECT=True
